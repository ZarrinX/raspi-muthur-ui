[Unit]
Description=raspi-muthur-ui — MU/TH/UR SPI telemetry dashboard
After=network.target

[Service]
Type=simple
User=zrice
WorkingDirectory=/opt/raspi-muthur-ui
ExecStart=/opt/raspi-muthur-ui/venv/bin/python main.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
